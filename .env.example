# MongoDB подключение
# Комментируйте USE_REAL_MONGODB для использования in-memory БД (рекомендуется для dev)
# Раскомментируйте и установите в 'true' для использования реальной MongoDB
# USE_REAL_MONGODB=true

# Реквизиты для подключения к реальной MongoDB
DATABASE_URL=mongodb://localhost:27017/chat-app
DATABASE_USER=admin
DATABASE_PASSWORD=your_password_here

# Базовый URL фронтенда (для ссылок в письмах сброса пароля)
# Для dev с Parcel обычно http://localhost:1234
FRONTEND_BASE_URL=http://localhost:1234

# Настройки SMTP для отправки писем (по умолчанию настроено под MailHog)
# Для запуска MailHog: docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
#SMTP_USER=
#SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# Время жизни токена сброса пароля (мс), по умолчанию 1 час
PASSWORD_RESET_EXPIRES_MS=3600000